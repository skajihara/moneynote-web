# ─────────────────────────────────────────────────────────────────────────────
# MoneyNote Web - 環境変数テンプレート
# このファイルをコピーして .env を作成してください。
# .env は .gitignore で除外済みのため絶対にコミットしないこと。
# ─────────────────────────────────────────────────────────────────────────────

# Database
DB_URL=jdbc:postgresql://localhost:5432/moneynote
DB_USERNAME=moneynote
DB_PASSWORD=your_strong_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
# セキュリティ: 本番環境では必ず openssl rand -base64 64 で生成したランダム文字列を使用すること
# 例: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# Cookie
# nginx + mkcert により開発環境も HTTPS のため true に設定する
COOKIE_SECURE=true

# Frontend URL（CORS 許可オリジン）
# nginx が HTTPS を終端するため https://localhost を使用する
FRONTEND_URL=https://localhost

# Claude API Key
CLAUDE_API_KEY=sk-ant-api03-your-api-key-here

# ─────────────────────────────────────────────────────────────────────────────
# 本番環境専用（spring.profiles.active=prod 時のみ参照）
# ─────────────────────────────────────────────────────────────────────────────

# Mail（本番用 SMTP。開発環境は application.yml の mailhog を使用）
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=noreply@example.com
# MAIL_PASSWORD=your_smtp_password_here
