# ─────────────────────────────────────────────────────────────────────────────
# MoneyNote Web - 環境変数テンプレート
# このファイルをコピーして .env を作成してください。
# .env は .gitignore で除外済みのため絶対にコミットしないこと。
# ─────────────────────────────────────────────────────────────────────────────

# ─── データベース ─────────────────────────────────────────────
# Docker Compose 内からは "db" ホスト名でアクセスする（localhost ではない）
DB_URL=jdbc:postgresql://db:5432/moneynote
DB_USERNAME=moneynote
DB_PASSWORD=your_strong_password_here

# ─── Redis ───────────────────────────────────────────────────
# Docker Compose 内からは "redis" ホスト名でアクセスする
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ─── JWT ─────────────────────────────────────────────────────
# セキュリティ: 本番環境では必ず openssl rand -base64 64 で生成したランダム文字列を使用すること
# 例: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_USE_OPENSSL_RAND_BASE64_64

# ─── Cookie ──────────────────────────────────────────────────
# nginx + mkcert により開発環境も HTTPS のため true に設定する
# 本番環境では必ず true を設定すること（application-env1.yml / application-env2.yml でも強制される）
COOKIE_SECURE=true

# ─── CORS ────────────────────────────────────────────────────
# フロントエンドのオリジン（CORS 許可先）
# nginx が HTTPS を終端するため https://localhost を使用する
# 本番環境では実際のドメイン（例: https://moneynote.example.com）に変更すること
FRONTEND_URL=https://localhost

# ─── Claude API ──────────────────────────────────────────────
# Anthropic Console で取得した API キー
# https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-api03-your-api-key-here

# ─── メール管理者アドレス ─────────────────────────────────────
# 問い合わせメールの送信先（管理者メールアドレス）
# 開発環境では MailHog で受信するため任意の値を設定してよい
ADMIN_EMAIL=admin@example.com

# ─────────────────────────────────────────────────────────────
# AWS環境専用（spring.profiles.active=env1/env2 時のみ参照）
# scripts/secrets-fetch.sh で自動生成される .env.env1 / .env.env2 に記載される
# ─────────────────────────────────────────────────────────────

# ─── メール（SMTP） ──────────────────────────────────────────
# 開発環境は application.yml の ${MAIL_HOST:mailhog} / ${MAIL_PORT:1025} デフォルト値を使用するためコメントアウト
# AWS環境では secrets-fetch.sh が SES エンドポイントを設定する
# MAIL_HOST=email-smtp.ap-northeast-1.amazonaws.com
# MAIL_PORT=587
# MAIL_USERNAME=your_ses_smtp_username
# MAIL_PASSWORD=your_ses_smtp_password
# MAIL_FROM=admin@example.com
