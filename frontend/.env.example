# ─────────────────────────────────────────────────────────────────────────────
# MoneyNote Web - フロントエンド環境変数テンプレート
# このファイルをコピーして .env.local を作成してください。
# .env.local は .gitignore で除外済みのため絶対にコミットしないこと。
# ─────────────────────────────────────────────────────────────────────────────

# ─── API エンドポイント ───────────────────────────────────────
# バックエンド API の URL（NEXT_PUBLIC_ プレフィックスでブラウザから参照可能）
# Docker Compose 経由で nginx が終端する場合は https://localhost を使用する
# 本番環境では実際のドメイン（例: https://api.moneynote.example.com）に変更すること
NEXT_PUBLIC_API_URL=https://localhost
