# ─────────────────────────────────────────────────────────────────────────────
# MoneyNote Web - バックエンド環境変数テンプレート
# このファイルをコピーして .env を作成してください。
# .env は .gitignore で除外済みのため絶対にコミットしないこと。
# ─────────────────────────────────────────────────────────────────────────────

# ─── データベース ─────────────────────────────────────────────
# Docker Compose 内からは "db" ホスト名でアクセスする（localhost ではない）
DB_URL=jdbc:postgresql://db:5432/moneynote
DB_USERNAME=moneynote
DB_PASSWORD=your_strong_password_here

# ─── Redis ───────────────────────────────────────────────────
# Docker Compose 内からは "redis" ホスト名でアクセスする
REDIS_HOST=redis
REDIS_PORT=6379

# ─── JWT ─────────────────────────────────────────────────────
# セキュリティ: 本番環境では必ず openssl rand -base64 64 で生成したランダム文字列を使用すること
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_USE_OPENSSL_RAND_BASE64_64

# ─── Cookie ──────────────────────────────────────────────────
# nginx + mkcert により開発環境も HTTPS のため true に設定する
# 本番環境では必ず true を設定すること
COOKIE_SECURE=true

# ─── CORS ────────────────────────────────────────────────────
# フロントエンドのオリジン（CORS 許可先）
# 本番環境では実際のドメイン（例: https://moneynote.example.com）に変更すること
FRONTEND_URL=https://localhost

# ─── Claude API ──────────────────────────────────────────────
# Anthropic Console で取得した API キー（https://console.anthropic.com/）
# 開発環境では ai.mock=true にすることで API 呼び出しを回避できる
CLAUDE_API_KEY=sk-ant-api03-your-api-key-here
