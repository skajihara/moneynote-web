# seed.ps1 は PowerShell が UTF-8 BOM 付きを要求するため CRLF 固定
seed.ps1  text eol=crlf working-tree-encoding=UTF-8

# シェルスクリプトは LF のみ
seed.sh   text eol=lf

# ソースコード・設定ファイルは LF
*.md      text eol=lf
*.java    text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.sql     text eol=lf
*.xml     text eol=lf
*.gradle  text eol=lf
*.sh      text eol=lf
